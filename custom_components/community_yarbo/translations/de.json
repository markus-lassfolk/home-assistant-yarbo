  "issues": {
    "telemetry_timeout": {
      "title": "Yarbo-Telemetrie nicht empfangen",
      "description": "Seit mindestens 60 Sekunden wurde keine Telemetrie von **{name}** empfangen. Überprüfe, ob die Basisstation eingeschaltet und mit dem Netzwerk verbunden ist."
    },
    "mqtt_disconnect": {
      "title": "Yarbo-Basisstation nicht erreichbar",
      "description": "Seit mindestens 60 Sekunden wurde keine Telemetrie von **{name}** empfangen. Der Roboter könnte außer Reichweite sein oder die Basisstation ist ausgeschaltet.\n\n**Schritte zur Behebung:**\n1. Überprüfe, ob das Yarbo Data Center (Basisstation) eingeschaltet ist.\n2. Stelle sicher, dass die Basisstation mit deinem lokalen Netzwerk verbunden ist.\n3. Bestätige, dass Home Assistant die IP-Adresse der Basisstation erreichen kann.\n\nDieses Problem löst sich automatisch, wenn die Telemetrie wieder aufgenommen wird."
    },
    "controller_lost": {
      "title": "Yarbo-Controller-Sitzung verloren",
      "fix_flow": {
        "step": {
          "confirm": {
            "title": "Controller neu erwerben",
            "description": "Die Yarbo-App oder ein anderer Client hat die Controller-Sitzung für **{name}** übernommen und verhindert, dass Home Assistant Befehle sendet.\n\nDrücke **Absenden**, um die Controller-Sitzung neu zu erwerben."
          }
        },
        "abort": {
          "cannot_connect": "Die Controller-Sitzung konnte nicht neu erworben werden. Überprüfe, ob die Yarbo-Basisstation erreichbar ist, und versuche es erneut.",
          "unknown": "Ein unerwarteter Fehler ist beim Neuerwerb der Controller-Sitzung aufgetreten."
        }
      }
    },
    "cloud_token_expired": {
      "title": "Yarbo-Cloud-Sitzung abgelaufen",
      "fix_flow": {
        "step": {
