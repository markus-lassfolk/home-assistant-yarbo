      "not_implemented": "Konfigurationsablauf noch nicht implementiert.",
      "wrong_device": "Das entdeckte Gerät stimmt nicht mit diesem Yarbo-Roboter überein.",
      "reconfigure_successful": "Neukonfiguration erfolgreich abgeschlossen.",
      "reconfigure_failed": "Neukonfiguration fehlgeschlagen.",
      "reauth_successful": "Neu-Authentifizierung erfolgreich."
