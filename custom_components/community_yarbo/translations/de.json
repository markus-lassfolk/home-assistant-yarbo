{
  "config": {
    "step": {
      "user": {
        "title": "Mit Yarbo verbinden",
        "description": "Gib die IP-Adresse deiner Yarbo-Basisstation (Data Center) ein. Die Integration verbindet sich mit dem lokalen MQTT-Broker auf Port 1883.",
        "data": {
          "broker_host": "IP-Adresse der Basisstation",
          "broker_port": "MQTT-Port"
        }
      },
      "manual": {
        "title": "Verbindungsdetails eingeben",
        "description": "Es wurden keine Yarbo-Geräte im Netzwerk gefunden. Bitte gib die IP-Adresse der Basisstation und den MQTT-Port manuell ein.",
        "data": {
          "broker_host": "IP-Adresse der Basisstation",
          "broker_port": "MQTT-Port"
        }
      },
      "confirm": {
        "title": "Yarbo entdeckt",
        "description": "**Yarbo {name}** wurde in deinem Netzwerk unter {host} gefunden. Klicke auf Absenden, um diesen Roboter hinzuzufügen."
      },
      "select_endpoint": {
        "title": "MQTT-Endpunkt auswählen",
        "description": "Wir haben **{count}** Pfad(e) zu deinem Yarbo-Mäher gefunden (Reihenfolge nach Entdeckung: Primär, dann Sekundär). Beide verbinden sich mit demselben Broker. Ein Failover versucht den nächsten in dieser Reihenfolge, wenn der aktuelle nicht verfügbar ist.",
        "data": {
          "selected_endpoint": "Endpunkt"
        }
      },
      "mqtt_test": {
        "title": "Verbinde mit Yarbo",
        "description": "Teste die MQTT-Verbindung und warte auf Telemetrie von deinem Roboter..."
      },
      "reconfigure": {
        "title": "Yarbo neu konfigurieren",
        "description": "Aktualisiere die IP-Adresse deiner Yarbo-Basisstation.",
        "data": {
          "broker_host": "IP-Adresse der Basisstation",
          "broker_port": "MQTT-Port"
        }
      },
      "name": {
        "title": "Benenne deinen Roboter",
        "description": "Wähle einen Namen für deinen Yarbo-Roboter. Dieser wird für alle Entitätsnamen verwendet.",
        "data": {
          "robot_name": "Robotername"
        }
      },
      "cloud": {
        "title": "Cloud-Funktionen (Optional)",
        "description": "Verbinde dich optional mit der Yarbo-Cloud für Firmware-Updates und Geräteinformationen. Für die lokale Steuerung nicht erforderlich. Leer lassen zum Überspringen.",
        "data": {
          "cloud_username": "Yarbo-Konto-E-Mail",
          "cloud_password": "Passwort"
        }
      },
      "reauth_confirm": {
        "title": "Yarbo Cloud neu authentifizieren",
        "description": "Deine Yarbo-Cloud-Sitzung für **{username}** ist abgelaufen. Gib dein Passwort ein, um dich erneut zu verbinden.",
        "data": {
          "cloud_password": "Passwort"
        }
      }
    },
    "abort": {
      "already_configured": "Dieser Roboter ist bereits konfiguriert.",
      "cannot_connect": "Keine Verbindung zum MQTT-Broker unter {host}:1883 möglich. Ist die Basisstation eingeschaltet und erreichbar?",
      "no_telemetry": "Verbunden, aber innerhalb von 10 Sekunden keine Roboter-Telemetrie empfangen. Ist der Roboter eingeschaltet?",
